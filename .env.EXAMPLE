# Discord Bot Token
DISCORD_TOKEN=

# [Optional] Path to SQLite database file. Defaults to ./quoter.db
SQLITE_DB_PATH=

# [Optional] IDs of users that should bypass cooldowns. Seperate multiple IDs with a space.
DISCORD_ADMIN_ID=

# [Optional] ID of guild to deploy commands to in development.
DISCORD_GUILD_ID=

# [Optional] Maximum quotes per guild. Can be changed per guild by setting maxGuildQuotes in the database.
MAX_GUILD_QUOTES=500

# [Optional] Maximum characters per quote. Can be changed per guild by setting maxQuoteLength in the database.
MAX_QUOTE_LENGTH=250
